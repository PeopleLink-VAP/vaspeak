# VASpeak Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it's in .gitignore.

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get a key at https://resend.com
RESEND_API_KEY=""

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# Get a key at https://console.groq.com
GROQ_API_KEY=""

# ── Admin Dashboard ───────────────────────────────────────────────────────────
ADMIN_AUTH_USER="admin"
ADMIN_AUTH_PASSWORD=""

# ── Turso (Admin Kanban DB) ───────────────────────────────────────────────────
# Get credentials at https://turso.tech
TURSO_DB_URL=""
TURSO_DB_TOKEN=""

# ── JWT Session ───────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=""

# ── Public URLs ───────────────────────────────────────────────────────────────
PUBLIC_BASE_URL="http://localhost:5173"
ORIGIN="http://localhost:5173"

# ── SQLite (App DB) ───────────────────────────────────────────────────────────
# Defaults to file:../db/local.db (relative to web/ dir). Leave blank for local dev.
# LIBSQL_DB_URL=""
# LIBSQL_AUTH_TOKEN=""
