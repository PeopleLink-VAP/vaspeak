{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "npx playwright test",
		"test:e2e": "npx playwright test tests/e2e --reporter=list",
		"test:api": "npx playwright test tests/api --reporter=list",
		"test:ui": "npx playwright test --ui",
		"test:unit": "vitest run --config tests/unit/vitest.config.ts",
		"test:unit:watch": "vitest --config tests/unit/vitest.config.ts",
		"test:unit:ui": "vitest --ui --config tests/unit/vitest.config.ts"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@vitest/ui": "^2.1.8",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^2.1.8"
	},
	"dependencies": {
		"@libsql/client": "^0.17.0",
		"@tailwindcss/vite": "^4.2.1",
		"tailwindcss": "^4.2.1"
	}
}
