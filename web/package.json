{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "npx playwright test",
		"test:e2e": "npx playwright test tests/e2e --reporter=list",
		"test:api": "npx playwright test tests/api --reporter=list",
		"test:ui": "npx playwright test --ui",
		"db:migrate": "node scripts/init-db.js",
		"db:seed": "node scripts/seed-lessons.js",
		"db:setup": "node scripts/init-db.js && node scripts/seed-lessons.js",
		"test:unit": "vitest run --config tests/unit/vitest.config.ts",
		"test:unit:watch": "vitest --config tests/unit/vitest.config.ts",
		"test:unit:ui": "vitest --ui --config tests/unit/vitest.config.ts",
		"test:e2e:record": "bash scripts/run-e2e-record.sh",
		"test:e2e:record:smoke": "bash scripts/run-e2e-record.sh --grep=@smoke"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/bcryptjs": "^2.4.6",
		"@types/dom-mediacapture-record": "^1.0.22",
		"@types/jsonwebtoken": "^9.0.10",
		"@vitest/ui": "^2.1.8",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^2.1.8"
	},
	"dependencies": {
		"@libsql/client": "^0.17.0",
		"@tailwindcss/vite": "^4.2.1",
		"bcryptjs": "^3.0.3",
		"disposable-email-domains": "^1.0.62",
		"groq-sdk": "^1.1.1",
		"jsonwebtoken": "^9.0.3",
		"tailwindcss": "^4.2.1"
	}
}
